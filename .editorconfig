# EditorConfig is awesome: https://EditorConfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{ps1,psm1}]
indent_style = space
indent_size = 4
max_line_length = 120

[*.{md,json,yml,yaml}]
indent_style = space
indent_size = 2

[*.html]
indent_style = space
indent_size = 2
max_line_length = 200

[*.css]
indent_style = space
indent_size = 4

[*.{js,ts}]
indent_style = space
indent_size = 2

[Makefile]
indent_style = tab
